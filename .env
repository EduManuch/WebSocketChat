ADDR="0.0.0.0"
PORT=":8443"
CERT="certs/cert.crt"
KEY="certs/key.pem"
TEMPLATEDIR="./web/templates/html"
STATICDIR="./web/static"
#KAFKA=enable
#BACKEND_TLS=enable
BACKEND_ORIGINS="localhost,localhost:8443,localhost:8444"
DEBUG=enable

# Указывается значение в секундах
TOKEN_TTL=300
JWT_SECRET="example-very-secret-key"
# Указывается значение в днях
REFRESH_TOKEN_TTL=30
REFRESH_JWT_SECRET="secret-for-refresh"
